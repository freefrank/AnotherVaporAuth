<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night + Android 12+ : transparent splash icon + dark background so no
         logo shows (night has higher resource precedence than -v31, so the
         splash attrs must live here too). -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/ava_launch_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
